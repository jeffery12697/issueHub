:3000 {
    # GitHub / GitLab webhook callbacks
    handle /webhooks/* {
        reverse_proxy backend:8000
    }

    # Backend REST API
    handle /api/* {
        reverse_proxy backend:8000
    }

    # WebSocket connections
    handle /ws/* {
        reverse_proxy backend:8000
    }

    # Frontend (React SPA + Vite HMR)
    handle {
        reverse_proxy frontend:5173
    }
}
